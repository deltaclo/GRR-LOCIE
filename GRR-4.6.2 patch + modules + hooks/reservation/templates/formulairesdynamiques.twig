{% extends 'layout.twig' %}

{% block css %}
<style>
    #formdyn-page{width:100%;max-width:1400px;margin:0 auto;padding:0 12px;box-sizing:border-box;}
    #formdyn-page .formdyn-main{min-width:0;}
    @media (max-width:767px){
        #formdyn-page{padding:0;}
    }
</style>
{% endblock %}

{% block content %}
<section id="formdyn-page">
    <main class="formdyn-main">
        {{ d.CtnPage|raw }}
    </main>
</section>
{% endblock %}
